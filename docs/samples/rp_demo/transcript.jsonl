, 255]}, {"sys": 197, "name": "Sarix", "alt": 12.0, "az": 85.2, "mag": 6.42, "rgb": [249, 245, 255]}, {"sys": 831, "name": "Narix", "alt": 27.0, "az": 283.8, "mag": 6.45, "rgb": [239, 239, 255]}, {"sys": 11, "name": "Hator", "alt": 0.7, "az": 331.4, "mag": 6.46, "rgb": [214, 223, 255]}, {"sys": 493, "name": "Sator", "alt": 25.1, "az": 118.7, "mag": 6.49, "rgb": [240, 240, 255]}], "companion_star": {"alt": 17.5, "az": 66.4, "mag": -13.4, "up": true}}, "refpack": {"skyline_report": ["四望开阔，地平线上没有显著的山影"], "skyline": {"az_deg": [0.0, 10.0, 20.0, 30.0, 40.0, 50.0, 60.0, 70.0, 80.0, 90.0, 100.0, 110.0, 120.0, 130.0, 140.0, 150.0, 160.0, 170.0, 180.0, 190.0, 200.0, 210.0, 220.0, 230.0, 240.0, 250.0, 260.0, 270.0, 280.0, 290.0, 300.0, 310.0, 320.0, 330.0, 340.0, 350.0], "elev_angle_deg": [0.05, 0.09, 0.13, 0.16, 0.19, 0.21, 0.22, 0.22, 0.21, 0.2, 0.18, 0.15, 0.12, 0.08, 0.04, -0.01, -0.05, -0.1, -0.14, -0.18, -0.22, -0.25, -0.27, -0.29, -0.3, -0.31, -0.3, -0.29, -0.27, -0.25, -0.22, -0.18, -0.14, -0.09, -0.05, 0.0]}, "lighting": {"period": "night", "报告": "夜晚；月色明亮，地面有影；澜月last quarter(照明0.39，未升)；缇月waning gibbous(照明0.81，在天)；暗红伴日在天"}}, "status": "closed", "entries": [{"type": "say", "id": 1, "scene": 1, "seat": "凯尔", "layer": "action", "text": "我低头把最后一处裂缝仔细抹上油，随后将驮鞍翻过来检查皮带扣，确认没有松动，才起身朝赛芮走去，在她对面的木箱上坐下。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 2, "scene": 1, "seat": "凯尔", "layer": "dialogue", "text": "明早要是没睡好，路上就靠着车厢眯一会儿。王都的路比镇外难走，别把行李抱得太紧，手会酸。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 3, "scene": 1, "seat": "凯尔", "layer": "inner", "text": "我真正想问的是，你有没有听说过王都里关于“转生者”的传闻。可这话现在不能说……连我自己都还没准备好，去面对那个可能早已等着我的答案。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 4, "scene": 1, "seat": "赛芮", "layer": "action", "text": "我把怀里的行李又往臂弯里收了收，指尖隔着布料压住那本密封的底簿，抬眼看向凯尔，却只点了点头，没有起身靠近。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 5, "scene": 1, "seat": "赛芮", "layer": "dialogue", "text": "嗯，我会记着。明早路上若困了，我就靠着车厢歇一会儿……谢谢你提醒。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 6, "scene": 1, "seat": "赛芮", "layer": "inner", "text": "别太快放松，也别让人看出我怀里真正护着的是什么。只要平安到王都，把密卷交到能护住它的人手里，我就能再撑一阵。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 7, "scene": 1, "seat": "凯尔", "layer": "action", "text": "我顺着她按住行李的手看了一眼，没有追问，只起身把火塘旁一条干燥的旧毯子拿来，放在她身侧的木箱上，又退回原处坐下。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 8, "scene": 1, "seat": "凯尔", "layer": "dialogue", "text": "夜里湿气重，别一直抱着行李，垫在身后会舒服些。要是里面有怕压坏的东西，明早我替你放到车厢里稳妥的位置。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 9, "scene": 1, "seat": "凯尔", "layer": "inner", "text": "她护得太紧了，里面那本底簿恐怕比我想的更重要。我很想问她究竟要把它带去王都见谁，可一旦开口，我们之间最后那点默契也许就会裂开。", "arbiter_note": null, "edited": false}, {"type": "say", "id": 10, "scene": 1, "seat": "KP", "layer": "narration", "text": "货栈掌柜进来收灯油钱，顺口说：驿马今天下午到的，王都出事了。", "arbiter_note": null, "edited": false}]}
{"type": "say", "id": 1, "scene": 1, "seat": "凯尔", "layer": "action", "text": "我低头把最后一处裂缝仔细抹上油，随后将驮鞍翻过来检查皮带扣，确认没有松动，才起身朝赛芮走去，在她对面的木箱上坐下。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 2, "scene": 1, "seat": "凯尔", "layer": "dialogue", "text": "明早要是没睡好，路上就靠着车厢眯一会儿。王都的路比镇外难走，别把行李抱得太紧，手会酸。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 3, "scene": 1, "seat": "凯尔", "layer": "inner", "text": "我真正想问的是，你有没有听说过王都里关于“转生者”的传闻。可这话现在不能说……连我自己都还没准备好，去面对那个可能早已等着我的答案。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 4, "scene": 1, "seat": "赛芮", "layer": "action", "text": "我把怀里的行李又往臂弯里收了收，指尖隔着布料压住那本密封的底簿，抬眼看向凯尔，却只点了点头，没有起身靠近。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 5, "scene": 1, "seat": "赛芮", "layer": "dialogue", "text": "嗯，我会记着。明早路上若困了，我就靠着车厢歇一会儿……谢谢你提醒。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 6, "scene": 1, "seat": "赛芮", "layer": "inner", "text": "别太快放松，也别让人看出我怀里真正护着的是什么。只要平安到王都，把密卷交到能护住它的人手里，我就能再撑一阵。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 7, "scene": 1, "seat": "凯尔", "layer": "action", "text": "我顺着她按住行李的手看了一眼，没有追问，只起身把火塘旁一条干燥的旧毯子拿来，放在她身侧的木箱上，又退回原处坐下。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 8, "scene": 1, "seat": "凯尔", "layer": "dialogue", "text": "夜里湿气重，别一直抱着行李，垫在身后会舒服些。要是里面有怕压坏的东西，明早我替你放到车厢里稳妥的位置。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 9, "scene": 1, "seat": "凯尔", "layer": "inner", "text": "她护得太紧了，里面那本底簿恐怕比我想的更重要。我很想问她究竟要把它带去王都见谁，可一旦开口，我们之间最后那点默契也许就会裂开。", "arbiter_note": null, "edited": false}
{"type": "say", "id": 10, "scene": 1, "seat": "KP", "layer": "narration", "text": "货栈掌柜进来收灯油钱，顺口说：驿马今天下午到的，王都出事了。", "arbiter_note": null, "edited": false}
{"type": "settle", "scene": 1, "elapsed_days": 0.5, "day_after": 137.5, "events": [{"desc": "老王病危的急报贴到了镇公所门口", "visibility": "public", "place": [-166.74764827180502, -23.34045177090505], "changeset": "628b995594"}], "distributed": [{"to": "俄洛", "arrives_day": 141.19, "desc": "老王病危的急报贴到了镇公所门口"}], "summary": "出发前夜：急报与不安"}